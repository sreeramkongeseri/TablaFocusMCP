# Path to bundled or external Tabla Focus datasets.
# Default: ./data/samples
TABLA_MCP_DATA_DIR=./data/samples

# Path to curated board metadata and references.
# Default: ./data/curated
TABLA_MCP_CURATED_DATA_DIR=./data/curated

# Max tool calls per minute per tool name.
# Default: 120
TABLA_MCP_RATE_LIMIT_PER_MINUTE=120

# Keep composition selection deterministic.
# true|false, default true
TABLA_MCP_DETERMINISTIC=true

# Log level used by server internals.
# debug|info|warn|error
TABLA_MCP_LOG_LEVEL=info
