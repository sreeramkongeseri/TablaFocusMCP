{
  "name": "tablafocus-mcp",
  "version": "0.1.2",
  "description": "Universal Tabla MCP server powered by Tabla Focus content and deterministic composition engines.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tablafocus-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "data/samples/",
    "data/curated/",
    "assets/tablafocus-mcp-icon.png",
    "assets/tablafocus-mcp-icon.svg",
    "server.json",
    "docs/mcp/",
    "docs/ARCHITECTURE.md",
    "docs/DATA_PROVENANCE.md",
    "docs/DATA_LICENSE.md",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "private": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx scripts/demo.ts",
    "content:sync": "node scripts/sync-webpage-content.mjs",
    "content:check:freshness": "node scripts/sync-webpage-content.mjs --check",
    "registry:check": "node scripts/verify-registry-metadata.mjs",
    "smoke:package": "node scripts/smoke-package.mjs",
    "prepack": "npm run build",
    "prepare": "node scripts/prepare.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreeramkongeseri/TablaFocusMCP.git"
  },
  "keywords": [
    "mcp",
    "tabla",
    "music",
    "education"
  ],
  "author": "TablaFocusMCP Contributors",
  "mcpName": "io.github.sreeramkongeseri/tablafocus-mcp",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sreeramkongeseri/TablaFocusMCP/issues"
  },
  "homepage": "https://github.com/sreeramkongeseri/TablaFocusMCP#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}
