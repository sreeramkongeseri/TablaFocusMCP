{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "practice_coach input",
  "type": "object",
  "required": ["goals", "availability"],
  "properties": {
    "profile_id": { "type": "string" },
    "goals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "availability": {
      "type": "object",
      "properties": {
        "daily_minutes": { "type": "integer", "minimum": 1, "maximum": 600 },
        "weekly_minutes": { "type": "integer", "minimum": 1, "maximum": 4000 },
        "days_per_week": { "type": "integer", "minimum": 1, "maximum": 7 }
      },
      "additionalProperties": false
    },
    "week_context": {
      "type": "object",
      "properties": {
        "missed_days": { "type": "integer", "minimum": 0, "maximum": 7 },
        "completed_minutes": { "type": "integer", "minimum": 0, "maximum": 4000 },
        "fatigue": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
